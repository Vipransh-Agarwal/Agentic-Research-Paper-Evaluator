# LLM Providers (Choose one or multiple based on your setup)
# For Native Google Gemini API:
GEMINI_API_KEY="your_gemini_api_key_here"

# For OpenRouter (Access any model via a single API):
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Search Tools
SEMANTIC_SCHOLAR_API_KEY="your_semantic_scholar_api_key_here" # Optional, often works without but recommended

# --- LLM Selection & Control ---
# The application uses LiteLLM for routing. YOU MUST USE THE CORRECT PREFIX:
# 1. Native Gemini:  "gemini/gemini-3.1-flash-lite-preview"
# 2. OpenRouter:     "openrouter/google/gemini-3.1-flash-lite-preview"
# 3. Local (Ollama): "ollama/llama3"
#
# IMPORTANT: Ensure your model is a CHAT/INSTRUCT model. 
# Do NOT use "embed" models (e.g., nvidia/...-embed-...) as they will crash the application.
LLM_MODEL="openrouter/google/gemini-3.1-flash-lite-preview" 

# Context window safety (Max tokens per LLM call)
MAX_TOKENS_PER_CHUNK=16000
MAX_OUTPUT_TOKENS=16000 # Max tokens for LLM response (prevents OpenRouter credit errors)
